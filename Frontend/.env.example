# Supabase (pega em https://app.supabase.com/project/YOUR-PROJECT/api/keys)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API
VITE_API_URL=http://localhost:8080
# Produção (HTTPS)
# VITE_API_URL=https://api.seudominio.com

# Mercado Pago (pega em https://www.mercadopago.com.br/developers/panel)
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-your-public-key-here
# Produção: use a public key de produção (APP_USR/PROD) da mesma conta/token do backend
